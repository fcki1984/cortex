# Cortex Server
CORTEX_PORT=21100
CORTEX_HOST=127.0.0.1
CORTEX_DB_PATH=cortex/brain.db

# Dashboard auth token (optional - leave empty to disable auth)
# When set, the dashboard requires this token to access, and all API calls need Bearer auth.
# CORTEX_AUTH_TOKEN=your-secret-token-here

# OpenAI-compatible extraction LLM
# Use provider=openai + custom base URL for any OpenAI-compatible gateway.
CORTEX_LLM_EXTRACTION_PROVIDER=openai
CORTEX_LLM_EXTRACTION_MODEL=qwen-plus
CORTEX_LLM_EXTRACTION_BASE_URL=https://your-openai-compatible.example.com/v1
CORTEX_LLM_EXTRACTION_API_KEY=sk-your-compat-key

# Lifecycle LLM
# If you want extraction and lifecycle to use the same model, copy the same values.
CORTEX_LLM_LIFECYCLE_PROVIDER=openai
CORTEX_LLM_LIFECYCLE_MODEL=qwen-plus
CORTEX_LLM_LIFECYCLE_BASE_URL=https://your-openai-compatible.example.com/v1
CORTEX_LLM_LIFECYCLE_API_KEY=sk-your-compat-key

# Embedding model (configure dimensions to match your provider/model)
CORTEX_EMBEDDING_PROVIDER=openai
CORTEX_EMBEDDING_MODEL=text-embedding-v3
CORTEX_EMBEDDING_BASE_URL=https://your-openai-compatible.example.com/v1
CORTEX_EMBEDDING_API_KEY=sk-your-compat-key
CORTEX_EMBEDDING_DIMENSIONS=1024

# Legacy compatibility vars (optional)
# OPENAI_API_KEY=sk-your-openai-key-here
# OLLAMA_BASE_URL=http://localhost:11434

# Changing embedding models or dimensions requires reindexing vectors from Dashboard -> Settings -> Reindex Vectors.

# Timezone (for Docker - e.g. Asia/Shanghai, Asia/Tokyo, America/New_York)
# TZ=UTC

# Logging
LOG_LEVEL=info
